# ========================================
# Frontend - Variáveis de Ambiente (Vite)
# ========================================

# 📌 URL da API Backend
# Desenvolvimento: http://localhost:3000
# Produção: https://api.seu-dominio.com
# Nota: Variáveis com prefixo VITE_ são expostas ao navegador
VITE_API_URL=http://localhost:3000

# 🔧 Modo de Desenvolvimento
# Disponível como import.meta.env.VITE_DEV em tempo de compilação
VITE_DEV_MODE=true

