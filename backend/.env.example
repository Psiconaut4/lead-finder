# ========================================
# Backend - Variáveis de Ambiente
# ========================================

# 🔑 NVIDIA API (LLM para análise)
# Obtenha em: https://build.nvidia.com/
# Modelos disponíveis:
#   - mistralai/mistral-7b-instruct-v0.2 (RECOMENDADO)
#   - mistralai/mistral-small-4-119b-2603
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=mistralai/mistral-7b-instruct-v0.2

# ========================================
# CORS - Configuração de Origens Permitidas
# ========================================

# Modo de Ambiente
# Valores: development | production
NODE_ENV=development

# URLs do Frontend (separadas por vírgula, SEM espaços)
# Desenvolvimento: http://localhost:5173,http://127.0.0.1:5173
# Produção: https://seu-dominio.com,https://www.seu-dominio.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ========================================
# Server
# ========================================

# Porta do Backend
PORT=3000

# Host do servidor
# localhost = apenas conexões locais
# 0.0.0.0 = aceita conexões externas (usar em produção com cuidado)
HOST=localhost

